          }
        },
        {
          "name": "Get Workflow Stats",
          "method": "GET",
          "url": "{{baseUrl}}/api/v1/workflows/summary/stats",
          "auth": {
            "type": "bearer",
            "bearer": "{{token}}"
          }
        }
      ]
    },
    {
      "name": "9. Health & Info",
      "requests": [
        {
          "name": "Health Check",
          "method": "GET",
          "url": "{{baseUrl}}/health"
        },
        {
          "name": "Root Info",
          "method": "GET",
          "url": "{{baseUrl}}/"
        }
      ]
    }
  ],
  "environments": [
    {
      "name": "Local Development",
      "variables": [
        {
          "name": "baseUrl",
          "value": "http://localhost:8000"
        },
        {
          "name": "token",
          "value": ""
        }
      ]
    }
  ]
