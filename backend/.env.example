# Application
APP_NAME=FinPilot AI
APP_VERSION=1.0.0
DEBUG=True
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/finpilot
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-here-change-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OpenAI / AI Configuration
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_TEMPERATURE=0.7
OPENAI_MAX_TOKENS=2000
AI_CONVERSATION_MAX_HISTORY=20
AI_CONTEXT_WINDOW=8000

# File Upload & Document Processing
MAX_UPLOAD_SIZE=10485760
UPLOAD_DIR=./uploads
ALLOWED_FILE_TYPES=pdf,docx,doc,txt,png,jpg,jpeg
DOCUMENT_RETENTION_DAYS=365
TESSERACT_PATH=C:/Program Files/Tesseract-OCR/tesseract.exe

# Celery & Background Tasks
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_ALWAYS_EAGER=False
CELERY_TASK_TRACK_STARTED=True
CELERY_TASK_TIME_LIMIT=300
CELERY_WORKER_PREFETCH_MULTIPLIER=4

# Simulation Settings
SIMULATION_MAX_YEARS=50
SIMULATION_DEFAULT_INFLATION_RATE=0.03
SIMULATION_DEFAULT_RETURN_RATE=0.07
SIMULATION_MONTE_CARLO_ITERATIONS=1000

# Workflow Settings
WORKFLOW_MAX_EXECUTIONS_PER_DAY=100
WORKFLOW_EXECUTION_TIMEOUT=300
WORKFLOW_RETRY_ATTEMPTS=3
WORKFLOW_RETRY_DELAY=60

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@finpilot.ai
ENABLE_EMAIL_NOTIFICATIONS=True

# External APIs (Bank Integration)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret
PLAID_ENV=sandbox